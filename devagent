#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIBS_DIR="$ROOT_DIR/build/libs"
FORCE_BOOT_JAR="${DEVAGENT_FORCE_BOOTJAR:-false}"

if [[ $# -eq 0 ]]; then
  set -- help
fi

build_boot_jar() {
  "$ROOT_DIR/gradlew" --quiet bootJar
}

find_boot_jar() {
  local jar_path=""
  local candidates=()
  local jar

  shopt -s nullglob
  for jar in "$LIBS_DIR"/*.jar; do
    if [[ "$jar" == *"-plain.jar" ]]; then
      continue
    fi
    candidates+=("$jar")
    if [[ -z "$jar_path" || "$jar" -nt "$jar_path" ]]; then
      jar_path="$jar"
    fi
  done
  shopt -u nullglob

  if [[ ${#candidates[@]} -eq 0 ]]; then
    return 1
  fi

  printf '%s\n' "$jar_path"
}

needs_boot_jar_build() {
  local jar_path="$1"
  local candidate

  if [[ "$(printf '%s' "$FORCE_BOOT_JAR" | tr '[:upper:]' '[:lower:]')" == "true" ]]; then
    return 0
  fi
  if [[ -z "$jar_path" ]]; then
    return 0
  fi

  for candidate in \
    "$ROOT_DIR/build.gradle" \
    "$ROOT_DIR/build.gradle.kts" \
    "$ROOT_DIR/settings.gradle" \
    "$ROOT_DIR/settings.gradle.kts" \
    "$ROOT_DIR/gradle.properties"; do
    if [[ -f "$candidate" && "$candidate" -nt "$jar_path" ]]; then
      return 0
    fi
  done

  for candidate in "$ROOT_DIR/src" "$ROOT_DIR/gradle" "$ROOT_DIR/buildSrc"; do
    if [[ -d "$candidate" && -n "$(find "$candidate" -type f -newer "$jar_path" -print -quit 2>/dev/null)" ]]; then
      return 0
    fi
  done

  return 1
}

BOOT_JAR="$(find_boot_jar || true)"
if needs_boot_jar_build "${BOOT_JAR:-}"; then
  build_boot_jar
fi

BOOT_JAR="$(find_boot_jar)"
if [[ -z "$BOOT_JAR" ]]; then
  echo "[devagent-cli] 실행 실패: boot jar를 찾을 수 없습니다. ($LIBS_DIR)" >&2
  exit 1
fi

exec java -jar "$BOOT_JAR" "$@"
